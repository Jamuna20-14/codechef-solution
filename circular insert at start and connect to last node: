circular insert at start and connect to last node:

class Node:
    def __init__(self, data):
        self.data = data
        self.next = None


class CircularLinkedList:
    def __init__(self):
        self.head = None

    def append(self, data):
        new_node = Node(data)

        if not self.head:
            self.head = new_node
            new_node.next = self.head
        else:
            current = self.head
            while current.next != self.head:
                current = current.next

            current.next = new_node
            new_node.next = self.head

    def insert_begin(self, data):
        new_node = Node(data)

        if not self.head:
            self.head = new_node
            new_node.next = self.head
        else:
            current = self.head

            # find last node
            while current.next != self.head:
                current = current.next

            # last node points to new node
            current.next = new_node

            # new node points to old head
            new_node.next = self.head

            # update head
            self.head = new_node

    def traverse(self):
        if not self.head:
            print("List is empty")
            return

        current = self.head
        while True:
            print(current.data, end=" => ")
            current = current.next
            if current == self.head:
                break


# Example
cll = CircularLinkedList()

cll.append(10)
cll.append(20)
cll.append(30)

print("Before insertion:")
cll.traverse()

print("\nAfter inserting 40 at beginning:")
cll.insert_begin(40)
cll.traverse()
