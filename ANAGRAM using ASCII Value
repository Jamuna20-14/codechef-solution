s1 = input("Enter first string: ").lower()
s2 = input("Enter second string: ").lower()

if len(s1) != len(s2):
    print("Not Anagram")
else:
    count = [0] * 256  # ASCII array

    for ch in s1:
        count[ord(ch)] += 1

    for ch in s2:
        count[ord(ch)] -= 1

    if all(x == 0 for x in count):
        print("Anagram")
    else:
        print("Not Anagram")


