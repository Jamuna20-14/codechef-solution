class Node:
    def __init__(self, data):
        self.data = data
        self.next = None
        self.prev = None
head = Node(10)
head.next = Node(20)
head.next.prev = head
head.next.next = Node(30)
head.next.next.prev = head.next

current = head

while current is not None:
    prev_data = current.prev.data if current.prev else None
    next_data = current.next.data if current.next else None

    print("Prev:", prev_data,
          "Current:", current.data,
          "Next:", next_data)
    current = current.next

o/p:
Prev: None Current: 10 Next: 20
Prev: 10 Current: 20 Next: 30
Prev: 20 Current: 30 Next: None
